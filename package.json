{
  "name": "client_demo_fw5-playwright",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "pretest": "bddgen",
    "test": "node scripts/run-tests-with-report.js",
    "pretest:smoke": "bddgen",
    "test:smoke": "node scripts/run-tests-with-report.js --grep @smoke",
    "pretest:regression": "bddgen",
    "test:regression": "node scripts/run-tests-with-report.js --grep @regression",
    "test:ci": "bddgen && node scripts/run-tests-with-report.js --reporter=github --skip-open",
    "bddgen": "bddgen",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "report:html": "playwright show-report",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "report:allure": "npm run allure:generate && npm run allure:open",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "dotenv": "^17.4.2",
    "playwright-bdd": "^9.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
